# =============================================================================
# Family Assistant - Docker Compose Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the required values
# Required variables are marked with (REQUIRED)
# Optional variables have default values shown


# =============================================================================
# PostgreSQL Database Configuration
# =============================================================================
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_PORT=5432


# =============================================================================
# Backend Service Configuration
# =============================================================================

# Server Configuration
LOG_LEVEL=INFO
ENVIRONMENT=development
BACKEND_PORT=8080

# CORS Configuration
# Comma-separated list of allowed origins
CLIENT_ORIGINS=http://localhost:3000,http://localhost:5173

# Authentication Configuration
AUTH_DISABLED=false

# Google OAuth Configuration (REQUIRED)
# Get your client ID from https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Comma-separated list of allowed Google Workspace domains (optional)
# Leave empty to allow any domain
ALLOWED_HOSTED_DOMAINS=

# Session Secret Key (REQUIRED)
# Generate a secure random value: openssl rand -hex 32
SESSION_SECRET_KEY=your-secure-random-session-secret-key-here

# LLM Backend Configuration
# Docker Compose defaults to the bundled Ollama service
LLM_BASE_URL=http://ollama:11434
LLM_TIMEOUT_SECONDS=120
LLM_MODEL=qwen2.5:7b


# =============================================================================
# Frontend Service Configuration
# =============================================================================
FRONTEND_PORT=3000

# API Base URL - should match backend service URL
VITE_API_BASE_URL=http://localhost:8080

# Google OAuth Client ID - must match the backend configuration (REQUIRED)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com


# =============================================================================
# Notes
# =============================================================================
# 1. Google OAuth Setup:
#    - Both GOOGLE_OAUTH_CLIENT_ID and VITE_GOOGLE_CLIENT_ID must be the same
#    - Create OAuth credentials at https://console.cloud.google.com/apis/credentials
#    - Add authorized JavaScript origins: http://localhost:3000
#    - Add authorized redirect URIs: http://localhost:3000
#
# 2. Session Secret Key:
#    - Generate with: openssl rand -hex 32
#    - Keep this secret and never commit it to version control
#
# 3. LLM Server:
#    - Docker Compose now includes an Ollama service by default
#    - For local non-Docker development, point LLM_BASE_URL at your host server
#    - See apps/llm-server/README.md for setup instructions
#
# 4. Database:
#    - PostgreSQL data persists in a Docker volume
#    - To reset: docker compose down -v (WARNING: deletes all data)
