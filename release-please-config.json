{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "separate-pull-requests": true,
  "include-component-in-tag": true,
  "packages": {
    "apps/assistant-backend": {
      "release-type": "python",
      "package-name": "assistant-backend",
      "changelog-path": "apps/assistant-backend/CHANGELOG.md",
      "extra-files": [
        {
          "type": "yaml",
          "path": "docker-compose.yml",
          "jsonpath": "$['x-assistant-backend-version']"
        }
      ]
    },
    "apps/assistant-ui": {
      "release-type": "node",
      "package-name": "assistant-ui",
      "changelog-path": "apps/assistant-ui/CHANGELOG.md",
      "extra-files": [
        {
          "type": "yaml",
          "path": "docker-compose.yml",
          "jsonpath": "$['x-assistant-ui-version']"
        }
      ]
    }
  }
}
